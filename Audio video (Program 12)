<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<title>Audio and Video Player</title>

<style>
body {
    margin: 0;
    padding: 30px;
    font-family: Arial, sans-serif;
    background: linear-gradient(135deg, #ffecd2, #fcb69f, #a1c4fd, #c2e9fb);
    min-height: 100vh;
    text-align: center;
}

h2 {
    color: #2c2c2c;
    margin-top: 25px;
}

.container {
    width: 50%;
    margin: auto;
    padding: 25px;
    background: linear-gradient(145deg, #ffffff, #f0f8ff);
    border-radius: 15px;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.25);
}

img, audio, video {
    display: block;
    width: 90%;
    margin: 15px auto;
    border-radius: 10px;
}

video {
    max-height: 300px;
}
</style>

</head>

<body>

<div class="container">

<h2>Image</h2>
<img src="4.jpg" alt="Nature Image" />

<h2>Audio Player</h2>
<audio controls>
    <source src="dooron.mp3" type="audio/mpeg">
    Your browser does not support the audio element.
</audio>

<h2>Video Player</h2>
<video controls muted>
    <source src="video.mp4" type="video/mp4">
    Your browser does not support the video element.
</video>

</div>

</body>
</html>
