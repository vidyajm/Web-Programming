<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Password Strength Checker</title>

<style>
body {
    font-family: Verdana, sans-serif;
    /* Ocean-inspired gradient background */
    background: linear-gradient(135deg, #00c6ff, #0072ff, #00ffa3);
}

.box {
    width: 350px;
    margin: 120px auto;
    padding: 20px;
    background-color: #ffffff;
    border-radius: 8px;
    box-shadow: 0 5px 10px rgba(0, 0, 0, 0.3);
    text-align: center;
}

input {
    width: 90%;
    padding: 10px;
    margin: 10px 0;
    font-size: 14px;
}

button {
    padding: 8px 15px;
    background-color: darkblue;
    color: white;
    border: none;
    border-radius: 5px;
    cursor: pointer;
}

#msg {
    margin-top: 15px;
    font-size: 16px;
    font-weight: bold;
}
</style>

<script>
function checkStrength() {
    let pwd = document.getElementById("pwd").value;
    let msg = document.getElementById("msg");

    let hasUpper = false;
    let hasLower = false;
    let hasDigit = false;
    let hasSpecial = false;

    for (let i = 0; i < pwd.length; i++) {
        let ch = pwd[i];

        if (ch >= 'A' && ch <= 'Z') {
            hasUpper = true;
        } else if (ch >= 'a' && ch <= 'z') {
            hasLower = true;
        } else if (ch >= '0' && ch <= '9') {
            hasDigit = true;
        } else {
            hasSpecial = true;
        }
    }

    if (pwd.length === 0) {
        msg.innerHTML = "Please enter a password";
        msg.style.color = "black";

    } else if (pwd.length < 6) {
        msg.innerHTML = "Weak Password";
        msg.style.color = "red";

    } else if (pwd.length >= 8 && hasUpper && hasLower && hasDigit && hasSpecial) {
        msg.innerHTML = "Strong Password";
        msg.style.color = "green";

    } else {
        msg.innerHTML = "Medium Password";
        msg.style.color = "orange";
    }
}
</script>

</head>

<body>

<div class="box">
    <h2>Password Strength</h2>
    <input type="password" id="pwd" placeholder="Enter password" />
    <br />
    <button onclick="checkStrength()">Check</button>
    <p id="msg"></p>
</div>

</body>
</html>
